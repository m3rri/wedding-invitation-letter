{
  "presets": [
    [
      "next/babel",
      {
        "preset-react": {
          "runtime": "automatic",
          "importSource": "@emotion/react"
        }
      }
    ]
  ],
  "plugins": [
    [
      "@emotion/babel-plugin"
    ],
    [
      "module-resolver",
      {
        "root": ["."],
        "alias": {
          "@c": "./src/components",
          "@s": "./src/styles"
        },
        "extensions": [".js", ".jsx", ".css"]
      }
    ]
  ]
}